.env
.env.*
!.env.example
# ── Python version pins (local machine-specific) ─────────────────────────
.python-version
# ── Virtual environments ─────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
# ── Python bytecode & cache ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
# ── Distribution / build ─────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
MANIFEST
.eggs/
# ── Type checking & linting caches ──────────────────────────────────────
.mypy_cache/
.ruff_cache/
.pytype/
.pyre/
# ── Testing ──────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/
*.coveragerc
.tox/
# ── ADK runtime data ─────────────────────────────────────────────────────
# Session database and trace files created by `adk web`
research_agent/.adk/
# ── Jupyter notebooks checkpoints ────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb
# ── OS artifacts ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
# ── IDEs ─────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
# ── uv ───────────────────────────────────────────────────────────────────
