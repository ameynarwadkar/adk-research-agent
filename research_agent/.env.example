# ── Environment variables for Google ADK + Azure OpenAI ──────────────────
#
# Copy this file to research_agent/.env and fill in your values.
# Never commit .env — it is in .gitignore.
#
# ─────────────────────────────────────────────────────────────────────────

# Disable Vertex AI backend (use LiteLLM instead)
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# ── Azure OpenAI ──────────────────────────────────────────────────────────
# Azure Portal → your OpenAI resource → Keys and Endpoints
AZURE_API_KEY=your_azure_openai_key_here

# The base endpoint (no path, no query string)
AZURE_API_BASE=https://your-resource.openai.azure.com/

# API version shown in Azure AI Foundry
AZURE_API_VERSION=2025-04-01-preview

# The deployment name you created in Azure AI Foundry → Deployments
AZURE_DEPLOYMENT_ID=gpt-4o

# ── OpenAlex (optional) ───────────────────────────────────────────────────
# Adding your email places you in the OpenAlex "polite pool"
# which gives higher rate limits. No sign-up required.
# OPENALEX_EMAIL=your@email.com
