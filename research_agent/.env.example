# ── Environment variables for Google ADK + Vertex AI (Gemini) ────────────
#
# Copy this file to research_agent/.env and fill in your values.
# Never commit .env — it is in .gitignore.
#
# ─────────────────────────────────────────────────────────────────────────

# Use Vertex AI backend (Google Cloud)
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# Your Google Cloud project ID
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Region where your Vertex AI resources are deployed
# See: https://cloud.google.com/vertex-ai/docs/general/locations
GOOGLE_CLOUD_LOCATION=us-central1

# ── Authentication ────────────────────────────────────────────────────────
# Authenticate via Application Default Credentials before running:
#   gcloud auth application-default login
# No API key needed — ADC handles auth automatically.

# ── OpenAlex (optional) ───────────────────────────────────────────────────
# Adding your email places you in the OpenAlex "polite pool"
# which gives higher rate limits. No sign-up required.
# OPENALEX_EMAIL=your@email.com

# ── Langfuse Observability (optional) ────────────────────────────────────
# Tracing UI: https://cloud.langfuse.com
# LANGFUSE_SECRET_KEY="sk-lf-..."
# LANGFUSE_PUBLIC_KEY="pk-lf-..."
# LANGFUSE_HOST="https://cloud.langfuse.com"
